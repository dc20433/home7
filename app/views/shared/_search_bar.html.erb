<div class="row justify-content-center my-3">
  <%# Fixed the typo to border-primary %>
  <div class="col-md-8 border-lg border-primary rounded-pill pt-3 pb-3 bg-warning shadow-sm">
    <%= search_form_for q, url: url, method: :get, class: "d-flex gap-2 align-items-center" do |f| %>
  
      <%# Use local_assigns to safely check for the variable %>
      <%# Last Name Search %>
      <%= f.search_field (local_assigns[:search_key_last] || :last_name_cont), 
                         placeholder: "Last Name...", 
                         class: "form-control form-control-sm rounded-pill border-secondary px-3 shadow-sm" %>

      <%# First Name Search %>
      <%= f.search_field (local_assigns[:search_key_first] || :first_name_cont),
                         placeholder: "First Name...", 
                         class: "form-control form-control-sm rounded-pill border-secondary px-3 shadow-sm" %>
  
      <%= f.submit "Search", class: "btn btn-sm btn-outline-dark rounded-pill px-4 fw-bold shadow-sm" %>
      <%= link_to "Clear", url, class: "btn btn-sm btn-link text-muted text-decoration-none" %>
    <% end %>
  </div>
</div>