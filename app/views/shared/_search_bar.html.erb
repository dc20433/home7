<%# app/views/overviews/_search_bar.html.erb %>
<div class="row justify-content-center">
  <div class="col-8 border border-primary rounded-pill mt-2 py-1 bg-warning shadow-sm">
    <%= search_form_for q, url: url, method: :get, class: "d-flex gap-2 align-items-center justify-content-center flex-wrap" do |f| %>
  
      <%= f.search_field (local_assigns[:search_key_last] || :last_name_i_cont), 
                         placeholder: "Last Name...", 
                         class: "form-control form-control-sm rounded-pill px-3 fw-bold",
                         style: "width: 180px;" %>

      <%= f.search_field (local_assigns[:search_key_first] || :first_name_cont),
                         placeholder: "First Name...", 
                         class: "form-control form-control-sm rounded-pill px-3 fw-bold",
                         style: "width: 180px;" %>
  
      <div class="d-flex gap-1">
        <%= f.submit "Search", class: "btn btn-sm btn-dark border border-light border-2 rounded-pill px-4 fw-bold shadow-sm" %>
        <%= link_to "Clear", url, class: "btn btn-sm btn-outline-secondary rounded-pill text-decoration-none fw-bold bg-white px-3" %>
      </div>
    <% end %>
  </div>
</div>