<div class="card-header">
  <h2 class="card-title text-center">Filing</h2>
  <h3><%= render 'layouts/identifier' %></h3>
</div>

<div class="card mt-3 mx-auto border-primary" style="width: 33rem;">
  <div class="card shadow border-dark">

    <div class="card-body">
      <%= form_with(model: [@regi, @filing]) do |f| %>
        <% if @filing.errors.any? %>
          <div id="error_explanation">
            <h2><%= pluralize(@filing.errors.count, "error") %> prohibited this filing from being saved:</h2>
            <ul>
            <% @filing.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
            </ul>
          </div>
        <% end %>

        <div class="field fs-6">
          <b>Filed on</b>
          <% if f.object.respond_to?(:f_date) %>
            <%= f.date_field :f_date, class:"form-control form-control-sm border-primary fs-4" %>
          <% else %>
            <span class="text-muted small">(Date column missing in DB)</span>
          <% end %>
        </div>

        <div class="field"><br>
          <%= f.file_field :image,  class:'form-control border-primary' %>
        </div><br>
        
        <div class="field fs-6">
          <b><%= f.label :describe, "File Description" %></b><br>
          <%= f.text_area :describe,  class:'form-control border-primary fs-4' %>
        </div>

        <div class="btn-group m-2 pt-2" role="group"> 
          <%= f.submit "Save", class: "btn btn-sm btn-outline-primary outline-double rounded-pill px-3 m-2 fw-bold" %>
          <%= link_to "Patient Files", regi_filings_path, class: "btn btn-sm btn-outline-success outline-double rounded-pill px-2 m-2 fw-bold" %>   
          <%= link_to 'Go Back', :back, class: "btn btn-sm btn-outline-info outline-double rounded-pill px-2 m-2 fw-bold" %>
        </div>
      <% end %>
    </div>
  </div>
</div>