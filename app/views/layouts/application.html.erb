<!doctype html>
<html lang="en">
  <head>
    <title>Home 7</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <style>
      /* This ensures the trees are always the base layer of the site */
      body {
  background: 
    /* Layer 1: The Tint (Must be listed FIRST to sit on TOP) */
    linear-gradient(rgba(105, 105, 100, 0.2), rgba(105, 105, 100, 0.2)), 
    /* Layer 2: The Trees */
    url('<%= asset_path("pine_trees.jpg") %>'); 

  background-size: cover;
  background-position: center;
  background-attachment: fixed;
  background-repeat: no-repeat;
  
  /* This ensures the colors underneath don't bleed through strangely */
  background-color: #f4f1ea; 
  margin: 1px;
  padding: 1px;
       
      }
      /* For the Big 5 views, we can add a solid background to cover the trees if they make the table hard to read */
      .full-width-bg {
        background-color: white; /* Or light grey #f8f9fa */
        min-height: 100vh;
      }
      .logo-float {
        position: absolute;
        top: 5px;
        bottom: 15px;
        right: 25px;
        z-index: 2000;
      }
    </style>
  </head>

  <body>
  <%# 1. The Logo remains absolute %>
  <div class="logo-float">
    <%= image_tag "title_2.png", style: "height: 35px; width: auto;", alt: "Zhang's Acupuncture", class: "pb-2" %>
  </div>

  <% 
    # Define the Big 5 that NEED full width
    full_width_views = [
      ["charts", "index"], 
      ["patients", "index"], 
      ["overviews", "chart_date"], 
      ["overviews", "chart_name"], 
      ["overviews", "patient_info"]
    ]

    # Check if the current page is in the Big 5 list
    is_full_width = full_width_views.any? { |c, a| params[:controller] == c && params[:action] == a }
  %>

  <%# 2. The Dynamic Container %>
  <%# If NOT full width (like regis/index), we use 'container mt-5' to show the trees on the sides %>
  <div class="<%= is_full_width ? 'container-fluid p-0' : 'container mt-5' %>">
    <%= render "layouts/alert" %>
    
    <div class="row m-0 justify-content-center">
      <%# For non-full-width pages, col-lg-10 keeps the content centered with trees visible %>
      <div class="<%= is_full_width ? 'col-12' : 'col-lg-10' %>">
        <%= yield %>
      </div>
    </div>
  </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>