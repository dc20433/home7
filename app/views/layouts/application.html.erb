<!doctype html>
<html lang="en">
  <head>
    <title>Home 7</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%# RE-ADDED BOOTSTRAP CSS - This brings back the buttons and grid %>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <style>
      body {
        margin: 0;
        padding: 0;
        background-color: #f4f1ea;
      }

      /* This wrapper holds the pinetrees background for EVERY page */
      .main-background-wrapper {
        background: 
          linear-gradient(rgba(105, 105, 100, 0.2), rgba(105, 105, 100, 0.2)), 
          url('<%= asset_path("pine_trees.jpg") %>');
        background-size: cover;
        background-position: center top;
        background-attachment: fixed;
        background-repeat: no-repeat;
        
        /* Ensures it fills the screen height minus the navbar */
        min-height: calc(100vh - 60px); 
        width: 100%;
      }

      /* Clean white box style for data tables (Big 5) */
      .white-data-card {
        background-color: rgba(255, 255, 255, 0.95);
        border-radius: 12px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.15);
        padding: 30px;
        margin-bottom: 30px;
      }
    </style>
  </head>

  <body data-authenticated="<%= authenticated? %>">
    <%# 1. Navbar is absolute top %>
    <%= render 'layouts/navbar' %>

    <% 
      c = params[:controller]
      a = params[:action]
      
      # Determine if we are on a "Big 5" data page
      is_big_5 = (c == "charts" && a == "index") ||
                 (c == "patients" && a == "index") ||
                 (c == "overviews" && ["chart_date", "chart_name", "patient_info"].include?(a))
      
      is_landing = (c == "sites" && a == "home")
      show_full_width = is_big_5 || is_landing
    %>

    <%# 2. Main Wrapper ensures the background is always "lowered" below the navbar %>
    <div class="main-background-wrapper">
      
      <%# p-0 for landing page to touch edges, mt-5 for others %>
      <div class="<%= show_full_width ? 'container-fluid p-0' : 'container pt-5' %>">
        <%= render "layouts/alert" %>
        
        <div class="row m-0 justify-content-center">
          <div class="<%= show_full_width ? 'col-12' : 'col-lg-10' %>">
            
            <%# Wrap Big 5 in a white card for readability %>
            <% if is_big_5 %>
              <div class="white-data-card mt-4">
                <%= yield %>
              </div>
            <% else %>
              <%= yield %>
            <% end %>

          </div>
        </div>
      </div>
    </div>

    <%# RE-ADDED BOOTSTRAP JS - Makes dropdowns and alerts work %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
      (function() {
        let timeout;
        const thirtyMinutes = 30 * 60 * 1000; // 30 minutes in milliseconds

        function resetTimer() {
          clearTimeout(timeout);
          // If the user is logged in, start the countdown
          if (document.body.dataset.authenticated === "true") {
            timeout = setTimeout(() => {
              // Redirect to the logout route
              window.location.href = "/session"; 
            }, thirtyMinutes);
          }
        }

        // List of events that count as "activity"
        const activityEvents = ['mousedown', 'mousemove', 'keypress', 'scroll', 'touchstart'];
        
        activityEvents.forEach(event => {
          document.addEventListener(event, resetTimer, true);
        });

        resetTimer(); // Initialize on page load
      })();
    </script>
  </body>
</html>