<!doctype html>
<html lang="en">
  <head>
    <title>Home 7</title>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=0">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <style>
      body { margin: 0; padding: 0; background-color: #f4f1ea; }

      .main-background-wrapper {
        background: linear-gradient(rgba(105, 105, 100, 0.3), rgba(105, 105, 100, 0.3)), 
                    url('<%= asset_path("pine_trees.jpg") %>');
        background-size: cover;
        background-position: center top;
        background-attachment: fixed;
        min-height: calc(100vh - 60px);
        width: 100%;
      }

      /* Update these lines in application.html.erb */
        .white-data-card {
          background-color: rgba(255, 255, 255, 0.0);
          border-radius: 12px;
          box-shadow: 0 10px 30px rgba(0,0,0,0.15);
          margin-bottom: 10px; /* Reduced from 30px to pull data lower [cite: 22] */
          width: 100%;
          max-width: 100%;
          margin-left: auto;
          margin-right: auto;
          overflow: visible; /* Changed from hidden to avoid trapping scrollbars [cite: 22, 23] */
    }

      @media (max-width: 1024px) {
        .white-data-card {
          padding-left: 0 !important;
          padding-right: 0 !important;
          border-radius: 8px;
        }
        
        /* Keeps buttons from touching the very edge since card padding is 0 */
        .alphabet-filter, .search-container, .card-header-actions {
          padding-left: 10px;
          padding-right: 10px;
        }

        .alphabet-filter .btn {
          padding: 2px 4px !important;
          font-size: 0.7rem !important;
          min-width: 20px;
        }
      }

      /* Ensures the search form doesn't stretch the card */
      .search-container {
        max-width: 95%;
        margin: 0 auto 1rem auto;
      }
       
      /* Add this to app/assets/stylesheets/application.css */
      .custom-table thead th {
        font-size: 1.15rem !important;
        font-weight: bold;
      }

      .custom-table tbody td {
        font-size: 1.5rem !important;
      }

      /* 1. Make the base checkbox larger and more visible */
      input[type="checkbox"] {
        appearance: none; /* Clear default browser styling */
        -webkit-appearance: none;
        width: 1.5rem;
        height: 1.5rem;
        border: 2px solid #333; /* Dark, thick border for empty boxes */
        border-radius: 4px;
        background-color: #fff;
        cursor: pointer;
        vertical-align: middle;
        position: relative;
        transition: all 0.2s ease;
      }

      /* 2. Styling for the Checked state */
      input[type="checkbox"]:checked {
        background-color: #0056b3; /* Bold blue background */
        border-color: #0056b3;
      }

      /* 3. Add a custom white "Checkmark" inside the box */
      input[type="checkbox"]:checked::after {
        content: '✔';
        position: absolute;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        color: white;
        font-size: 1rem;
        font-weight: bold;
      }

      /* 4. Hover effect for better UX */
      input[type="checkbox"]:hover {
        border-color: #007bff;
        box-shadow: 0 0 5px rgba(0, 123, 255, 0.5);
      }

      /* 5. Keep them pronounced when disabled (readonly mode) */
      input[type="checkbox"]:disabled {
        opacity: 0.8;
        cursor: not-allowed;
        border-color: #666;
      }

    </style>

  </head>

  <body>
    <%= render 'layouts/navbar' %>

    <% flash.each do |type, message| %>
      <div class="alert <%= type == 'alert' ? 'alert-danger' : 'alert-success' %> alert-dismissible fade show" role="alert">
        <%= message %>
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
    <% end %>
    
    <% 
    c = params[:controller]
    a = params[:action]
    
    # Expanded logic to include forms for patients and charts
    is_data_page = (c == "charts") || 
                   (c == "patients") || 
                   (c == "regis") || 
                   (c == "overviews") 
    
    is_landing = (c == "sites" && a == "home")
    show_full_width = (is_data_page || is_landing)
    %>

    <div class="main-background-wrapper">
      <div class="<%= show_full_width ? 'container-fluid p-0' : 'container pt-5' %>">
        <div class="row m-0 justify-content-center">
          <div class="<%= show_full_width ? 'col-12' : 'col-lg-11' %>">
            
            <% if is_data_page %>
              <div class="white-data-card mt-4">
                <%# Remove 'table-responsive' to stop the horizontal slider  %>
                <div class="data-container"> 
                  <%= yield %>
                </div>
              </div>
            <% else %>
              <%= yield %>
            <% end %>

          </div>
        </div>
      </div>
    </div>
  </body>
</html>