<div class="screen" style="background-image: url(<%= asset_path 'pine_trees.jpg' %>);">
  <div class="color-overlay d-flex justify-content-center mt-5 pt-5">
    <div class="card shadow border-dark" style="width: 25rem;">
      <div class="card-header bg-primary text-white text-center">
        <h4>Clinic Login</h4>
      </div>
      <div class="card-body">
        <%= form_with url: session_path do |f| %>
          <div class="mb-3">
            <%= f.label :email, "Email", class: "form-label fw-bold" %>
            <%= f.email_field :email, required: true, autofocus: true, class: "form-control border-primary" %>
          </div>

          <div class="mb-3">
            <%= f.label :password, "Password", class: "form-label fw-bold" %>
            <%= f.password_field :password, required: true, class: "form-control border-primary" %>
          </div>

          <div class="d-grid gap-2">
            <%= f.submit "Sign In", class: "btn btn-primary rounded-pill shadow" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

<%= link_to "Forgot password?", new_password_path %>
