<h2 class="text-center pt-4 pb-2">All Patient Charts by Date as of <%= Time.now.strftime("%Y-%m-%d %H:%M") %></h2>

<%= link_to 'All Charts by Name', overviews_chart_name_path, class:"btn btn-sm btn-dark border border-lg border-dark rounded-pill px-2 py-0 m-1 fw-bold" %>
<%= link_to 'All Patient Info', overviews_patient_info_path, class:"btn btn-sm btn-primary border border-lg border-dark rounded-pill px-2 py-0 m-1 fw-bold" %>
<%= link_to 'Patient List', regis_path, class:"btn btn-sm btn-warning border border-lg border-dark rounded-pill px-2 py-0 m-1 fw-bold" %>
<button onclick="window.print()", class="btn btn-sm btn-secondary border border-lg border-dark rounded-pill px-3 py-0 fw-bold">Print This Page</button>
<%= render 'shared/search_bar', q: @q, url: request.path, search_key: :regi_p_name_or_regi_first_name_or_regi_last_name_cont, placeholder: "Search charts by patient name..." %>

<table class="table table-sm table-striped table-hover mt-4">

  <thead class="table-info fs-6">
    <tr>
      <th style="width: 10%;">Date</th>
      <th style="width: 15%;">Name</th>
      <th style="width: 15%;">Subjective</th>
      <th style="width: 15%;">Objective</th>
      <th style="width: 15%;">Assessment</th>
      <th style="width: 30%;">Plan</th>
    </tr>
  </thead>

  </tbody>
    <% last_date = nil %>
    <% @charts.each do |chart| %>
    
    <tr style="height:15px" class="fs-4">
        <%# Only show the date if it's different from the previous row %>
      <td><%= chart.t_date != last_date ? chart.t_date : "" %></td>
        <% last_date = chart.t_date %>
      <td> 
        <%= link_to chart.regi.p_name, regi_charts_path(chart.regi_id) %>
        (<%= chart.regi.p_age %>)
      </td>
      <td><%= chart.subj %></td>
      <td><%= chart.obj %></td>
      <td><%= chart.assess %></td>
      <td><%= chart.plan %></td>
    </tr>
    <% end %>
  </tbody>
</table>

