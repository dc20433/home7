<h2 class="text-center py-2">All Patient Charts by Date as of <%= Time.now.strftime("%Y-%m-%d %H:%M") %></h2>

<div class="d-flex align-items-center justify-content-center mx-2 gap-1">
  <%= link_to 'All Charts by Name', overviews_chart_name_path, class:"btn btn-sm btn-success border border-light border-3 rounded-pill px-2 py-0 m-1 fw-bold" %>
  <%= link_to 'All Patient Info', overviews_patient_info_path, class:"btn btn-sm btn-info border border-light border-3 rounded-pill px-2 py-0 m-1 fw-bold" %>
  <%= link_to 'Patient List', regis_path, class:"btn btn-sm btn-warning border border-light border-3 rounded-pill px-3 py-0 m-1 fw-bold" %>
  <%= link_to 'Print All', 
              url_for(params.to_unsafe_h.merge(print: true)), 
              class: "btn btn-sm btn-secondary border border-light border-3 rounded-pill px-3 py-0 fw-bold" %>
</div>

<div class="row justify-content-center my-3">
  <div class="col-md-6 border border-primary rounded-pill py-1 bg-warning shadow-sm">
    <%= search_form_for @q, url: overviews_chart_date_path, method: :get, class: "d-flex gap-3 align-items-center px-4" do |f| %>
      
      <div class="d-flex align-items-center gap-2 flex-grow-1">
        <label class="fw-bold text-nowrap">From:</label>
        <%= f.date_field :t_date_gteq, class: "form-control form-control-sm rounded-pill border-secondary px-3 fw-bold" %>
      </div>

      <div class="d-flex align-items-center gap-2 flex-grow-1">
        <label class="fw-bold text-nowrap">To:</label>
        <%= f.date_field :t_date_lteq, class: "form-control form-control-sm rounded-pill border-secondary px-3 fw-bold" %>
      </div>

      <div class="d-flex gap-2">
        <%= f.submit "Search", class: "btn btn-sm btn-dark border border-light border-3 rounded-pill px-4 fw-bold shadow-sm" %>
        <%= link_to "Clear", overviews_chart_date_path, class: "btn btn-sm btn-link text-muted text-decoration-none fw-bolder" %>
      </div>
      
    <% end %>
  </div>
</div>

<table class="table table-sm table-striped table-hover border border-dark mt-4">

  <thead class="table-info fs-6">
    <tr>
      <th style="width: 8%;">Date</th>
      <th style="width: 17%;">Name</th>
      <th style="width: 20%;">Subjective</th>
      <th style="width: 15%;">Objective</th>
      <th style="width: 10%;">Assessment</th>
      <th class="text-center" style="width: 30%;">Plan</th>
    </tr>
  </thead>

  <tbody>
    <% last_date = nil %>
    <% @charts.each do |chart| %>
    
      <tr style="height:15px" class="fs-4">
          <%# Only show the date if it's different from the previous row %>
        <td><%= chart.t_date != last_date ? chart.t_date : "" %></td>
          <% last_date = chart.t_date %>
        <td> 
          <%= link_to chart.regi.p_name, regi_charts_path(chart.regi_id) %>
          (<%= chart.regi.p_age %>)
        </td>
        <td><%= chart.subj %></td>
        <td><%= chart.obj %></td>
        <td><%= chart.assess %></td>
        <td><%= chart.plan %></td>
      </tr>
    <% end %>
  </tbody>
</table>
<div class="d-flex justify-content-center my-4">
<%== pagy_bootstrap_nav(@pagy) if @pagy&.pages.to_i > 1 %>
</div>

<% if params[:print] == "true" %>
  <script>
    // This function runs as soon as the HTML is parsed
    (function() {
      const checkTable = setInterval(() => {
        // Look for the last row of your table to ensure 970+ records are there
        const rows = document.querySelectorAll('table tbody tr');
        if (rows.length > 0) {
          clearInterval(checkTable);
          // Small delay to let the browser "paint" the rows
          setTimeout(() => {
            window.print();
          }, 1000);
        }
      }, 100);
    })();
  </script>

  <style>
    @media print {
      /* Hide everything except the title and table */
      .btn, .nav, .search-bar, .d-flex, footer, .card-header { 
        display: none !important; 
      }
      body { background: white !important; }
      .table { width: 100% !important; border: 1px solid #000 !important; }
      /* Ensure text is black and readable */
      .fs-4 { color: #000 !important; font-size: 11pt !important; }
    }
  </style>
<% end %>