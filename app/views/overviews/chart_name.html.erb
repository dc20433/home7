<h2 class="text-center py-2">All Patient Charts by Name as of <%= Time.now.strftime("%Y-%m-%d %H:%M") %></h2>
<div class="d-flex align-items-center justify-content-center mx-2 gap-1">
<%= link_to 'All Charts by Date', overviews_chart_date_path, class:"btn btn-sm btn-dark outline-double border border-lg border-dark rounded-pill px-2 py-0 m-1 fw-bold" %>
<%= link_to 'All Patient Info', overviews_patient_info_path, class:"btn btn-sm btn-primary outline-double border border-lg border-primary rounded-pill px-2 py-0 m-1 fw-bold" %>
<%= link_to 'Patient List', regis_path, class:"btn btn-sm btn-success outline-double border border-lg border-success rounded-pill px-2 py-0 m-1 fw-bold" %>
<%= link_to 'Print All', 
            url_for(params.to_unsafe_h.merge(print: true)), 
            class: "btn btn-sm btn-secondary outline-double border border-lg border-secondary rounded-pill px-3 py-0 fw-bold" %>
</div>
<%= render 'shared/search_bar', 
    q: @q, 
    url: request.path, 
    search_key_last: :regi_last_name_cont,
    search_key_first: :regi_first_name_cont,
    placeholder: "Search Charts..." %>

    <div class="d-flex flex-wrap justify-content-center gap-1 my-3">
  <% ('A'..'Z').each do |letter| %>
    <%= link_to letter, 
                url_for(letter: letter), 
                class: "btn btn-sm btn-warning outline-double fw-bold #{params[:letter] == letter ? 'btn-primary' : 'btn-outline-secondary'} rounded-circle shadow-sm",
                style: "width: 35px;" %>
  <% end %>
  <%= link_to "All", url_for(letter: "All"), class: "btn btn-sm btn-warning outline-double rounded-pill px-3 shadow-sm" %>
</div>

<table class="table table-sm table-striped table-hover mt-4" style="table-layout: fixed; width: 100%; border-collapse: collapse;">
  <thead class="table-info fs-6">
    <tr>
      <th style="width: 17%;">Name</th> 
      <th style="width: 8%;">Date</th>
      <th style="width: 20%;">Subjective</th>
      <th style="width: 15%;">Objective</th>
      <th style="width: 10%;">Assessment</th>
      <th class="text-center" style="width: 30%;">Plan</th>
    </tr>
  </thead>
  <tbody>
    <% last_patient_id = nil %>
    <% @charts.each do |chart| %>
      <tr>
        <td style="word-break: break-all; white-space: normal; overflow: hidden;">
          <% if chart.regi_id != last_patient_id %>
            <%= link_to "#{chart.regi.p_name} (#{chart.regi.p_age})", regi_charts_path(chart.regi_id) %>
          <% end %>
        </td>
        <td><%= chart.t_date %></td>
        <td style="word-break: break-all; white-space: normal;"><%= chart.subj %></td>
        <td style="word-break: break-all; white-space: normal;"><%= chart.obj %></td>
        <td style="word-break: break-all; white-space: normal;"><%= chart.assess %></td>
        <td style="word-break: break-all; white-space: normal;"><%= chart.plan %></td>
      </tr>
      <% last_patient_id = chart.regi_id %>
    <% end %>
  </tbody>
</table>
<div class="d-flex justify-content-center my-4">
  <%== pagy_bootstrap_nav(@pagy) if @pagy&.pages.to_i > 1 %>
</div>

<% if params[:print] == "true" %>
  <script>
    (function() {
      const checkTable = setInterval(() => {
        const rows = document.querySelectorAll('table tbody tr');
        if (rows.length > 0) {
          clearInterval(checkTable);
          setTimeout(() => {
            window.print();
            // Automatically clean the URL after printing
            window.location.href = window.location.href.replace(/[&?]print=true/, '');
          }, 1000);
        }
      }, 100);
    })();
  </script>

  <style>
    @media print {
      .btn, .nav, .search-bar, .d-flex, footer, .card-header, .pagination { 
        display: none !important; 
      }
      body { background: white !important; margin: 0; }
      .table { width: 100% !important; border: 1px solid #000 !important; }
      .fs-4 { color: #000 !important; font-size: 11pt !important; }
    }
  </style>
<% end %>

