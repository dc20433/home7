<%# render "layouts/navbar" %>
  
  <h2 class="text-center">All Patient Information as of <%= Time.now.in_time_zone("America/New_York").strftime("%Y-%m-%d %H:%M") %></h2>

  <%= link_to 'All Charts by Date', overviews_chart_date_path, class:"btn btn-sm btn-outline-dark outline-double rounded-pill px-2 py-0 m-1 fw-bold" %>
  <%= link_to 'All Charts by Name', overviews_chart_name_path, class:"btn btn-sm btn-outline-info outline-double rounded-pill px-2 py-0 m-1 fw-bold" %>
  <%= link_to 'Patient List', regis_path, class:"btn btn-sm btn-outline-primary outline-double rounded-pill px-2 py-0 m-1 fw-bold" %>
  <button onclick="window.print()", class="btn btn-sm btn-outline-success outline-double rounded-pill px-3 py-0 fw-bold">Print This Page</button>

  <table class="table table-sm table-striped table-hover mt-2">
    <thead class="table-success fs-6">
    <tr style="height:13px">
        <th>Name</th>
        <th>Date Entered</th>
        <th>Contact Info</th>
        <th>Weight</th>
        <th>Complaints</th>
        <th>Onset/Pain</th>
        <th>Referred</th>
        <th>Health History</th>
      </tr>
    </thead>
    <tbody>
  <% last_patient_id = nil %>
  <% @patients.each do |patient| %>
    <tr style="height:15px">
      <td>
        <%# Only show name if it's a new patient group %>
        <% if patient.regi_id != last_patient_id %>
          <%= link_to "#{patient.regi.p_name} (#{patient.regi.p_age})", regi_patient_path(patient.regi_id, patient) %>
        <% end %>
      </td>

      <td><%= patient.v_date %></td>

      <td>
        <%= patient.street %><%= ', ' if patient.street.present? %>
        <%= patient.city %> <%= patient.state %> <%= patient.zip %>
        <br>
        <%= "C: #{patient.cell} " if patient.cell.present? %>
        <%= "H: #{patient.home} " if patient.home.present? %>
        <%= "W: #{patient.work} " if patient.work.present? %>
        <%= "E: #{patient.email}" if patient.email.present? %>
      </td>

      <td><%= patient.weight %></td>

      <td>
        <%= [patient.com1, patient.com2, patient.com3].select(&:present?).map(&:strip).join(' / ') %>
      </td>

      <td>
        <%= patient.d_onset %>
        <%= ' / Pain: ' + patient.pain_scale.to_s if patient.pain_scale.present? %>
      </td>

      <td><%= patient.referred %></td>

      <td>
        <% if patient.di_list.present? %>
          <%= patient.di_list.to_sentence(words_connector: '/', last_word_connector: '/').gsub(/_/, ' ').gsub(/;/, '') %>
        <% end %>
        <%= ' and ' + patient.o_dis if patient.o_dis.present? %>
        <%= ' and Pregnant' if patient.preg == 'Yes' %>
      </td>
    </tr>
    <%# Update the tracker at the end of the loop %>
    <% last_patient_id = patient.regi_id %>
  <% end %>
</tbody>
  </table>
