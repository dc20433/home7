<h2 class="text-center py-2">All Patient Information as of <%= Time.now.strftime("%Y-%m-%d %H:%M") %></h2>

<%# Navigation and Search remain unchanged %>
<div class="d-flex align-items-center justify-content-center mx-2 gap-1 no-print">
  <%= link_to 'All Charts by Date', overviews_chart_date_path, class:"btn btn-primary border border-light border-3 rounded-pill px-2 py-0 m-1 fw-bold" %>
  <%= link_to 'All Charts by Name', overviews_chart_name_path, class:"btn btn-success border border-light border-3 rounded-pill px-2 py-0 m-1 fw-bold" %>
  <%= link_to 'Patient List', regis_path, class:"btn btn-warning border border-light border-3 rounded-pill px-3 py-0 m-1 fw-bold" %>
  <%= link_to 'Print All', 
          url_for(params.to_unsafe_h.merge(print: true)), 
          class: "btn btn-secondary border border-light border-3 rounded-pill px-3 py-0 fw-bold" %>
</div>

<%= render 'shared/search_bar', 
  q: @q, 
  url: request.path, 
  search_key_last: :regi_last_name_cont,
  search_key_first: :regi_first_name_cont,
  placeholder: "Search Patient Info..." %>

<div class="d-flex flex-wrap justify-content-center gap-1 my-3 no-print">
  <% ('A'..'Z').each do |letter| %>
    <%= link_to letter, 
                url_for(letter: letter), 
                class: "btn btn-sm btn-warning border border-light border-3 fw-bold #{params[:letter] == letter ? 'btn-primary' : 'btn-outline-secondary'} rounded-circle shadow-sm",
                style: "width: 35px;" %>
  <% end %>
  <%= link_to "All", url_for(letter: "All"), class: "btn btn-sm btn-warning border border-light border-3 rounded-pill px-3 shadow-sm" %>
</div> 

<%# THE FIX: Single wrapper, no card, no fixed height containers %>
<div class="table-responsive" style="overflow-x: auto !important; overflow-y: visible !important; -webkit-overflow-scrolling: touch;">
  <table class="table table-sm table-striped table-hover custom-table mb-4" 
         style="table-layout: auto !important; width: auto !important; min-width: 1100px !important;">
    <thead class="table-success fs-6">
      <tr style="height:13px">
        <th class="ps-4">Name</th>
        <th>Date</th>
        <th>Contact Info</th>
        <th>Weight</th>
        <th>Complaints/Pain Scale</th>
        <th>Referral</th>
        <th class="text-center">Health History / Issues</th>
        <th class="text-center pe-4" style="width:120px">Signature</th>
      </tr>
    </thead>
    <tbody>
      <% last_patient_id = nil %>
      <% @patients.each do |patient| %>
        <tr style="height:15px">
          <td class="fw-bold ps-4">
            <% if patient.regi_id != last_patient_id %>
              <%= link_to "#{patient.regi.p_name} (#{patient.regi.p_age})", regi_patient_path(patient.regi_id, patient) %>
            <% end %>
          </td>
          <td class="small text-nowrap"><%= patient.v_date %></td>
          <td class="small">
            <%= patient.street %><%= ', ' if patient.street.present? %>
            <%= patient.city %> <%= patient.state %> <%= patient.zip %><br>
            <span class="text-muted">
              <%= "(c)#{patient.cell} " if patient.cell.present? %>
              <%= "(h)#{patient.home} " if patient.home.present? %>
            </span>
          </td>
          <td><%= patient.weight %></td>
          <td class="small">
            <%= [patient.com1, patient.com2, patient.com3, patient.pain_scale].select(&:present?).map(&:strip).join(' / ') %>
          </td>
          <td class="small"><%= patient.referred %></td>
          <td class="small">
            <%= (patient.di_list.to_sentence).gsub(/_/, ' ').gsub(/;/, '') %><%= ', ' if patient.o_dis? %>
            <%= patient.o_dis %><%= ', Pregnant' if patient.preg == 'Yes' %>
          </td>

          <%# Restored Paper Only badge %>
          <td class="text-center pe-4">
            <% if patient.signature.present? %>
              <span class="badge bg-success">Digital Sign</span>
            <% else %>
              <span class="badge bg-secondary">Paper Only</span>
            <% end %>
          </td>
        </tr>
        <% last_patient_id = patient.regi_id %>
      <% end %>
    </tbody>
  </table>
</div>

<div class="d-flex justify-content-center my-4 no-print">
  <%== pagy_bootstrap_nav(@pagy) if @pagy&.pages.to_i > 1 %>
</div>

<%# SCRIPT & STYLE BLOCK: One logic flow to prevent syntax errors %>
<% if params[:print] == "true" %>
  <script>
    (function() {
      const checkTable = setInterval(() => {
        const rows = document.querySelectorAll('table tbody tr');
        if (rows.length > 0) {
          clearInterval(checkTable);
          setTimeout(() => {
            window.print();
            window.location.href = window.location.href.replace(/[&?]print=true/, '');
          }, 1000);
        }
      }, 100);
    })();
  </script>

  <style>
    @media print {
      @page { size: landscape; margin: 0.5cm; }
      .btn, .nav, .search-bar, .d-flex, footer, .pagination, .no-print { display: none !important; }
      .table-responsive { display: block !important; overflow: visible !important; }
      table { width: 100% !important; table-layout: fixed !important; border: 1px solid #000 !important; }
      
      th:nth-child(1), td:nth-child(1) { width: 15%; }
      th:nth-child(3), td:nth-child(3) { width: 18%; }
      th:nth-child(5), td:nth-child(5) { width: 22%; }
      th:nth-child(6), td:nth-child(6) { width: 25%; }
      
      td, th { font-size: 8pt !important; border: 1px solid #ccc !important; padding: 2px !important; }
    }
  </style>
<% end %>

<style>
  @media screen {
    .table-responsive { width: 100% !important; overflow-x: auto !important; }
    .custom-table td, .custom-table th { 
      white-space: normal !important; 
      word-wrap: break-word; 
    }
  }
</style>