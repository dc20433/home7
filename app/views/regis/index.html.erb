

<div class="card mt-0 mx-auto border-primary" style="width: 70rem;">
  <div class="card shadow border-dark">
    <div class="card-header">
      <h2 class="card-title text-center p-4">Patient List as of <%= Time.now.strftime("%Y-%m-%d %H:%M") %></h2>
    </div>
    <div class="card-body">
  <%# Row 1: Action Buttons and Sign Out %>
  <div class="d-flex justify-content-between align-items-center m2-4">
    <div class="d-flex align-items-center gap-1">
      <%= link_to "New Patient", new_regi_path, class: "btn btn-sm btn-dark rounded-pill px-2 py-0 fw-bold" %>
      <%= link_to 'Charts by Date', overviews_chart_date_path, class: "btn btn-sm btn-primary rounded-pill px-2 py-0 fw-bold" %>
      <%= link_to 'Charts by Name', overviews_chart_name_path, class: "btn btn-sm btn-secondary rounded-pill px-2 py-0 fw-bold" %>
      <%= link_to 'Patient Info', overviews_patient_info_path, class: "btn btn-sm btn-info text-white rounded-pill px-2 py-0 fw-bold" %>
      <% if Current.user&.admin? %>
        <%= link_to 'Usage', overviews_statistics_path, class: "btn btn-sm btn-warning rounded-pill px-2 py-0 fw-bold" %>
      <% end %>
    </div>
  </div>

  <%# Row 2: Search Bar (Now truly on its own line) %>
  <div class="row mb-4 px-3">
    <div class="col-md-12">
       <%= render 'shared/search_bar', q: @q, url: regis_path, search_key: :p_name_or_first_name_or_last_name_cont, placeholder: "Search patient list..." %>
    </div>

      <table class="table table-sm table-striped table-hover mx-auto mt-2">
        <thead class="table-primary">
      
        <tr>
            <th style="width: 10%;">Last Name</th>
            <th style="width: 10%;">First Name</th>
            <th style="width: 5%;">M.I.</th>
            <th style="width: 10%;">Gender</th>
            <th style="width: 5%;">Age</th>
            <th class="text-nowrap" style="width: 15%;">Date of Birth</th>
            <th class="text-nowrap" style="width: 15%;">Created on</th>
            <th class="text-nowrap" style="width: 20%;"></th>
          </tr>

        </thead>
      <% @regis.each do |regi| %>
        <tr>
          <td><%= link_to regi.last_name, regi_path(regi.id) %></td>
          <td><%= regi.first_name %></td>
          <td><%= regi.init? ? regi.init + "." : "" %></td>
          <td><%= regi.gender %></td>
          <td><%= regi.p_age %></td>
          <td><%= regi.dob %></td>
          <td><%= regi.created_at.strftime("%Y-%m-%d") %></td>             
          <td>                
            <%= link_to 'Info', regi_patients_path(regi.id), class: "btn btn-sm btn-outline-info outline-double border border-lg border-info rounded-pill px-2 py-0 fw-bold" %>
            <%= link_to 'Charts', regi_charts_path(regi.id), class: "btn btn-sm btn-outline-primary outline-double border border-lg border-primary rounded-pill px-1 py-0 fw-bold" %>
            <%= link_to 'Files', regi_filings_path(regi.id), class: "btn btn-sm btn-outline-success outline-double border border-lg border-success rounded-pill px-2 py-0 fw-bold" %>
          </td>
        </tr>
        <% end %>
      </table>
    </div>
  </div>
</div>

