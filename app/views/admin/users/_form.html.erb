<div class="card shadow-sm border-0 rounded-4 p-4">
  <%= form_with(model: [:admin, user]) do |f| %>
    <div class="mb-3">
      <%= f.label :email, class: "form-label fw-bold" %>
      <%= f.email_field :email, class: "form-control rounded-3" %>
    </div>

    <div class="row mb-3">
      <div class="col">
        <%= f.label :role, class: "form-label fw-bold" %>
        <%= f.select :role, User.roles.keys.map { |r| [r.titleize, r] }, {}, class: "form-select rounded-3" %>
      </div>
      <div class="col">
        <%= f.label :is_active, "Account Status", class: "form-label fw-bold" %>
        <%= f.select :is_active, [["Active", true], ["Deactivated", false]], {}, class: "form-select rounded-3" %>
      </div>
    </div>

    <div class="mb-4">
      <%= f.label :password, class: "form-label fw-bold" %>
      <%= f.password_field :password, class: "form-control rounded-3", placeholder: "Leave blank to keep current" %>
    </div>

    <div class="d-grid gap-2">
      <%= f.submit "Save Manager Settings", class: "btn btn-primary btn-pill py-2" %>
      <%= link_to "Cancel", admin_users_path, class: "text-center text-muted text-decoration-none small" %>
    </div>
  <% end %>
</div>